{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/vendor/layout,_N_T_/dashboard/vendor/page,_N_T_/dashboard/vendor"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/vendor/__PAGE__",
    "/dashboard/vendor",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}